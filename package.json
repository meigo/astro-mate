{
  "name": "astro-mate",
  "version": "0.1.0",
  "description": "Focused CLI that generates Astro v6 + Tailwind v4 sites with Claude Code. Explicit stack, no guesswork.",
  "type": "module",
  "bin": {
    "astro-mate": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "check": "biome check src/",
    "check:fix": "biome check --write src/"
  },
  "dependencies": {
    "chalk": "^5.4.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
